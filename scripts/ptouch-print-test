#!/usr/bin/env python3
import argparse
import os
import sys
import time

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
SRC_DIR = os.path.join(REPO_ROOT, "src")
if SRC_DIR not in sys.path:
    sys.path.insert(0, SRC_DIR)

from ptouch_bt import (
    ConnectionConfig,
    FinalizeMode,
    build_test_print_job,
    format_status,
    ptouch_connection,
    request_status,
)
from ptouch_bt.printer import MAX_PIXELS, tape_width_px, write_print_job


def validate_status(status, label):
    if status.has_error:
        raise RuntimeError(f"{label}: printer reports error 0x{status.error_1:02x} 0x{status.error_2:02x}")


def validate_args(parser, args):
    if args.execute and args.dry_run:
        parser.error("--execute and --dry-run cannot be used together")
    if args.chain and args.feed_cut:
        parser.error("--chain and --feed-cut cannot be used together")
    if args.columns < 1:
        parser.error("--columns must be at least 1")
    if args.mark_width < 1 or args.mark_width > args.columns:
        parser.error("--mark-width must be between 1 and --columns")
    if args.mark_height < 1 or args.mark_height > MAX_PIXELS:
        parser.error(f"--mark-height must be between 1 and {MAX_PIXELS}")


def parse_args():
    parser = argparse.ArgumentParser(description="Build or print a tiny PT-P710BT test mark over RFCOMM.")
    parser.add_argument("--device", default=ConnectionConfig.device)
    parser.add_argument("--address", default=ConnectionConfig.address)
    parser.add_argument("--channel", type=int, default=ConnectionConfig.channel)
    parser.add_argument("--timeout", type=float, default=2.0)
    parser.add_argument("--columns", type=int, default=24)
    parser.add_argument("--mark-width", type=int, default=8)
    parser.add_argument("--mark-height", type=int, default=8)
    parser.add_argument("--execute", action="store_true", help="Actually send the print job. Without this, only print generated bytes.")
    parser.add_argument("--chain", action="store_true", help="Use chain/no-cut finalize 0x0c. This is the default when executing.")
    parser.add_argument("--feed-cut", action="store_true", help="Use 0x1a feed/cut finalize instead of chain/no-cut 0x0c.")
    parser.add_argument("--dry-run", action="store_true", help="Print generated bytes as hex. This is the default unless --execute is set.")
    args = parser.parse_args()
    validate_args(parser, args)
    return args


def finalize_mode(args):
    if args.feed_cut:
        return FinalizeMode.FEED_CUT
    return FinalizeMode.CHAIN


def print_dry_run(args):
    job = build_test_print_job(args.columns, args.mark_width, args.mark_height, finalize_mode(args))
    print(job.to_bytes().hex())


def validate_tape(status, mark_height):
    width = tape_width_px(status.media_width)
    if mark_height > width:
        raise RuntimeError(f"mark height {mark_height}px exceeds current tape printable width {width}px")


def run_print_test(args):
    config = ConnectionConfig(args.address, args.channel, args.device)
    job = build_test_print_job(args.columns, args.mark_width, args.mark_height, finalize_mode(args))

    with ptouch_connection(config) as fd:
        before = request_status(fd, args.timeout)
        validate_status(before, "before print")
        validate_tape(before, args.mark_height)

        print("before print:")
        print(format_status(before))

        byte_count, chunk_count = write_print_job(fd, job.chunks)
        print(f"sent:         {byte_count} bytes in {chunk_count} chunks")
        print(f"finalize:     {finalize_mode(args).label}")

        time.sleep(0.5)
        after = request_status(fd, args.timeout, drain_first=False)
        validate_status(after, "after print")
        print("after print:")
        print(format_status(after))


def main():
    args = parse_args()

    if not args.execute:
        print_dry_run(args)
        print("dry-run only; pass --execute to send this to the printer", file=sys.stderr)
        return 0

    try:
        run_print_test(args)
    except Exception as error:
        print(error, file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
