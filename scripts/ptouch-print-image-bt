#!/usr/bin/env python3
import argparse
import os
import sys

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
SRC_DIR = os.path.join(REPO_ROOT, "src")
if SRC_DIR not in sys.path:
    sys.path.insert(0, SRC_DIR)

from ptouch_bt import ConnectionConfig, FinalizeMode, ImageFit, PTouchPrinter, build_image_print_job, tape_width_px
from ptouch_bt.status import format_status


DEFAULT_CONFIG = ConnectionConfig()


def validate_args(parser, args):
    if args.execute and args.dry_run:
        parser.error("--execute and --dry-run cannot be used together")
    if args.chain and args.feed_cut:
        parser.error("--chain and --feed-cut cannot be used together")
    if args.tape_width_mm < 1:
        parser.error("--tape-width-mm must be at least 1")
    if args.threshold < 0 or args.threshold > 255:
        parser.error("--threshold must be between 0 and 255")


def parse_args():
    parser = argparse.ArgumentParser(description="Build or print an image label over PT-P710BT RFCOMM.")
    parser.add_argument("image")
    parser.add_argument("--device", default=DEFAULT_CONFIG.device)
    parser.add_argument("--address", default=DEFAULT_CONFIG.address)
    parser.add_argument("--channel", type=int, default=DEFAULT_CONFIG.channel)
    parser.add_argument("--timeout", type=float, default=2.0)
    parser.add_argument("--tape-width-mm", type=int, default=12, help="Tape width for dry-run rendering. Execute mode uses printer status.")
    parser.add_argument("--fit", choices=[fit.value for fit in ImageFit], default=ImageFit.CONTAIN.value)
    parser.add_argument("--dither", action=argparse.BooleanOptionalAction, default=True)
    parser.add_argument("--threshold", type=int, default=128, help="Black/white cutoff used with --no-dither.")
    parser.add_argument("--save-preview", help="Write the prepared 1-bit image before rasterization.")
    parser.add_argument("--execute", action="store_true", help="Actually send the print job. Without this, only print generated bytes.")
    parser.add_argument("--chain", action="store_true", help="Use chain/no-cut finalize 0x0c instead of the default feed/cut.")
    parser.add_argument("--feed-cut", action="store_true", help="Use 0x1a feed/cut finalize. This is the default when executing.")
    parser.add_argument("--dry-run", action="store_true", help="Print generated bytes as hex. This is the default unless --execute is set.")
    args = parser.parse_args()
    validate_args(parser, args)
    return args


def finalize_mode(args):
    if args.chain:
        return FinalizeMode.CHAIN
    return FinalizeMode.FEED_CUT


def print_dry_run(args):
    job = build_image_print_job(
        args.image,
        tape_width_px(args.tape_width_mm),
        finalize=finalize_mode(args),
        fit=args.fit,
        dither=args.dither,
        threshold=args.threshold,
    )
    if args.save_preview:
        job.image.save(args.save_preview)
        print(f"saved preview: {args.save_preview}", file=sys.stderr)
    print(job.to_bytes().hex())
    print(f"dry-run image: {job.image.size[0]}x{job.image.size[1]} px", file=sys.stderr)
    print(f"dry-run chunks: {job.chunk_count}, bytes: {job.byte_count}", file=sys.stderr)
    print("dry-run only; pass --execute to send this to the printer", file=sys.stderr)


def execute_print(args):
    print("This will consume tape and use feed/cut unless --chain was passed.", file=sys.stderr)
    printer = PTouchPrinter(
        ConnectionConfig(address=args.address, channel=args.channel, device=args.device),
        timeout=args.timeout,
    )
    result = printer.print_image(
        args.image,
        finalize=finalize_mode(args),
        fit=args.fit,
        dither=args.dither,
        threshold=args.threshold,
    )

    print("before print:")
    print(format_status(result.before))
    print(f"sent:         {result.byte_count} bytes in {result.chunk_count} chunks")
    print(f"finalize:     {result.finalize.label}")
    if result.after is not None:
        print("after print:")
        print(format_status(result.after))
    else:
        print(f"after print:  status unavailable: {result.after_error}")


def main():
    args = parse_args()

    if not args.execute:
        print_dry_run(args)
        return 0

    try:
        execute_print(args)
    except Exception as error:
        print(error, file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
